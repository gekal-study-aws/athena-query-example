{
  "name": "infra-sdk",
  "version": "0.1.0",
  "bin": {
    "infra-sdk": "bin/infra-sdk.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "format": "prettier --write \"**/*.{ts,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,json,md}\"",
    "cdk": "cdk",
    "cdk-deploy-infra": "cdk deploy InfraSdkStack",
    "cdk-destroy-infra": "cdk destroy InfraSdkStack",
    "cdk-diff-infra": "cdk diff InfraSdkStack",
    "cdk-synth-infra": "cdk synth InfraSdkStack",
    "cdk-deploy-ecs-service": "cdk deploy EcsServiceStack",
    "cdk-destroy-ecs-service": "cdk destroy EcsServiceStack",
    "cdk-diff-ecs-service": "cdk diff EcsServiceStack",
    "cdk-synth-ecs-service": "cdk synth EcsServiceStack"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^24.10.1",
    "aws-cdk": "2.1100.1",
    "jest": "^29.7.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "aws-cdk-lib": "2.232.1",
    "constructs": "^10.0.0"
  }
}
